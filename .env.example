# --- Server (Vercel environment variables, never shipped to the client) ---

# Neon Postgres connection string (Neon dashboard -> Connect -> Connection string)
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Secret used to sign session tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# --- Client (baked into the web bundle at build time) ---

# Base URL of the deployed API. Leave empty for the hosted PWA (same origin).
# REQUIRED for Android/Capacitor builds, e.g. https://your-app.vercel.app
VITE_API_BASE_URL=
